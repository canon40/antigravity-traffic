    async def start_engine(self):
        print("\n" + "#"*60)
        print(f"🚀 퍼마코트 랭킹 자동 적응형 엔진 가동")
        print(f"   - 타겟 목표: ★오늘 목표: 2페이지 안착★ (필요 예상 유입: 80~100건)")
        print(f"   - 엔진 최초 시작일: {self.config['start_date']}")
        print(f"   - 타겟 스토어: {self.config['store_name']}")
        print(f"   - 메인 키워드: {self.config['keyword']}")
        print("#"*60 + "\n")
        
        while True:
            # 날짜가 바뀌었으면 카운트 리셋
            today_str = datetime.now().strftime("%Y-%m-%d")
            if self.current_date_str != today_str:
                # 다음 날로 넘어가기 전 오늘의 Llama 보고서 출력
                await self.get_llama_report()
                
                self.current_date_str = today_str
                self.daily_hits_count = 0
                self.fail_hits_count = 0
                print(f"🌅 새로운 날짜({today_str})가 되어 유입량 카운터를 초기화합니다.")

            daily_target, next_delay = self.calculate_current_delay()
            
            print(f"📊 [오늘의 트래픽 현황] 현재 유입 횟수: {self.daily_hits_count} / 목표 유입량: {daily_target} 회")
            
            try:
                # 전체 과정을 7.5분(450초) 이내에 끝내도록 강제 제한 (파이썬 하위 버전을 고려해 wait_for 사용)
                await asyncio.wait_for(self.run_task(), timeout=450)
            except (asyncio.TimeoutError, TimeoutError):
                print("⏰ 시간이 너무 오래 걸려 작업을 강제 종료합니다. (타임아웃 방어 발동)")
                self.fail_hits_count += 1
                self.log_activity(100, 100, 0, "실패: 타임아웃")
            except Exception as e:
                print(f"❌ 엔진 구동 중 에러 발생: {e}")
                self.fail_hits_count += 1
                self.log_activity(100, 100, 0, f"실패: {str(e)[:20]}")
                
            self.daily_hits_count += 1
            
            # 계산된 지연 시간만큼 대기 (랜덤 오차 20% 부여)
            final_delay = int(next_delay * random.uniform(0.8, 1.2))
            
            # 대기 시간 사람이 보기 편하게 분/초로 환산 (테스트를 원하시면 10초 대기로 바꿀 수 있습니다)
            wait_m, wait_s = divmod(final_delay, 60)
            print(f"😴 다음 트래픽 작업까지 약 {wait_m}분 {wait_s}초 대기합니다...")
            print("💡 (안내: 화면이 갑자기 꺼진 것은 에러가 아닙니다. 로봇 의심을 피하기 위해 다음 타임을 기다리는 자연스러운 현상입니다.)")
            print("-"*60)
            await asyncio.sleep(final_delay)

