    # [0] Llama 전략 수립
    async def ask_llama_strategy(self, success_log):
        print("🧠 [Llama 두뇌] 데이터 분석 및 전략 수립 중...")
        prompt = f"""
        당신은 네이버 쇼핑 상위 노출 전문가입니다. 
        아래의 최근 유입 로그를 분석해서 '걸릴 확률 0%'를 위한 다음 작업 값을 정해주세요.
        로그: {success_log}
        
        결과는 반드시 아래 JSON 형식으로만 답변하세요. 마크다운 기호 없이 순수 JSON만 반환하세요:
        {{
            "dwell_time": (60~120 사이 정수),
            "scroll_speed": (1~5 사이 정수),
            "mouse_jitter": (0.1~0.5 사이 실수),
            "search_pattern": "직접검색" 또는 "연관검색어"
        }}
        """
        try:
            # ollama는 동기 라이브러리이므로 이벤트 루프 블로킹을 막기 위해 to_thread로 실행
            response = await asyncio.wait_for(
                asyncio.to_thread(
                    ollama.chat, 
                    model='llama3', 
                    messages=[{'role': 'user', 'content': prompt}]
                ),
                timeout=30.0
            )
            
            content = response['message']['content']
            # 마크다운 ```json ... ``` 등이 포함될 수 있으므로 전처리
            if "```json" in content:
                content = content.split("```json")[1].split("```")[0].strip()
            elif "```" in content:
                content = content.split("```")[1].split("```")[0].strip()
                
            strategy = json.loads(content)
            print(f"✅ [Llama 결정] 체류 시간: {strategy.get('dwell_time', 80)}초 | 스크롤 속도: {strategy.get('scroll_speed', 3)} | 마우스 지터: {strategy.get('mouse_jitter', 0.2)}")
            return strategy
        except Exception as e:
            print(f"❌ 분석 실패, 기본값으로 진행합니다. 오류: {e}")
            return {"dwell_time": 80, "scroll_speed": 3, "mouse_jitter": 0.2, "search_pattern": "직접검색"}

    # [0.5] 네이버 쇼핑 순위 확인 (백그라운드 스레드)
    async def check_naver_ranking(self, product_id=None):
        def _check():
            kw = getattr(self, 'run_keyword', self.config['keyword'])
            store_name = self.config['store_name']
            print(f"🔍 [{kw}] 순위 추적 시작...")
            url = f"https://m.search.naver.com/search.naver?query={quote(kw)}&where=m_shop"
            
            headers = {
                "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36"
            }
            
            try:
                res = requests.get(url, headers=headers, timeout=10)
                res.raise_for_status()
                text = res.text
                
                # Check for product ID in search results first if provided
                if product_id:
                    pid_str = str(product_id).strip()
                    if pid_str in text:
                        try:
                            from bs4 import BeautifulSoup
                            soup = BeautifulSoup(text, 'html.parser')
                            items = soup.select(".lst_item") or soup.select("div[class*='product_item']")
                            for idx, item in enumerate(items, 1):
                                if pid_str in str(item):
                                    print(f"🚩 현재 순위: {idx}위 (상품 ID {pid_str} 발견!)")
                                    return idx
                        except Exception:
                            pass
                
                # Fallback to store name matching
                from bs4 import BeautifulSoup
                soup = BeautifulSoup(text, 'html.parser')
                items = soup.select(".lst_item") or soup.select("div[class*='product_item']")
                
                if not items:
                    print("⚠️ 쇼핑 리스트를 불러오지 못했습니다. (네트워크나 셀렉터 확인 필요)")
                    return 100
                
                for idx, item in enumerate(items, 1):
                    if store_name in item.text:
                        print(f"🚩 현재 순위: {idx}위 (나눔랩 발견!)")
                        return idx
                
                print("⚠️ 1페이지 내에 상품이 없습니다. (100위 밖으로 간주)")
                return 100
        
            except Exception as e:
                print(f"❌ 접속 오류: {e}")
                return 100
                
        return await asyncio.to_thread(_check)

