    # [1] 자동 트래픽 양 조절 계산기 (시간대별/날짜별)
    def calculate_current_delay(self):
        now = datetime.now()
        # 날짜 경과에 따른 기본 유입량 계산
        start_dt = datetime.strptime(self.config['start_date'], "%Y-%m-%d")
        days_passed = (now - start_dt).days
        daily_target = self.config['base_daily_hits'] * (self.config['growth_rate'] ** days_passed)
        
        
        # 시간대별 가중치 (오후 2시 피크, 새벽 4시 최저)
        # Sine 함수를 이용해 자연스러운 흐름 생성
        hour_weight = (math.sin((now.hour - 8) * math.pi / 12) + 1.2) / 2
        hourly_target = (daily_target / 24) * hour_weight
        
        if hourly_target < 1: 
            return int(daily_target), random.randint(1800, 3600) # 유입 적은 시간엔 긴 대기
        return int(daily_target), int(3600 / hourly_target) # 다음 유입까지의 초(second) 계산

