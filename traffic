        for _ in range(random.randint(6, 12)):
            await page.mouse.wheel(0, random.randint(400, 900))
            await asyncio.sleep(random.uniform(base_sleep * 0.5, base_sleep * 1.5))
            
            if random.random() < jitter_prob:
