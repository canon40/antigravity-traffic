@echo off
chcp 65001 >nul
setlocal enabledelayedexpansion

cd /d "%~dp0"

if "%~1"=="" (
    echo =====================================================================
    echo  💡 사용 안내:
    echo  스마트스토어 순위 화면 캡처 이미지(PNG/JPG)를 
    echo  이 파일(run_rank_ocr_drag_here.bat) 아이콘 위로 드래그 앤 드롭해 주세요!
    echo =====================================================================
    echo.
    pause
    exit /b
)

echo.
echo ---------------------------------------------------------------------
echo  🤖 [나눔랩] 순위 대시보드 이미지 분석 및 비교 보고서 작성을 시작합니다.
echo ---------------------------------------------------------------------
echo  분석 대상 파일: %~1
echo.

.venv\Scripts\python.exe rank_ocr_reporter.py "%~1"

echo.
echo ---------------------------------------------------------------------
echo  작업 완료! 생성된 보고서는 generated_reports 폴더 안에 저장되었습니다.
echo ---------------------------------------------------------------------
echo.
pause
