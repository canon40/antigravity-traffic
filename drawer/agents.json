{
  "version": 2,
  "description": "프로그램 부팅 순서 + 에이전트 협업 순서",
  "principles": [
    "0단계: programs_check 통과 후 에이전트 시작",
    "동시에 여러 LLM 프로세스를 띄우지 않는다 (RAM/VRAM 절약)",
    "텍스트 생성 완료 후에만 이미지 생성을 시작한다",
    "Ollama → Gemini → Claude Code 순 폴백 (BLOG_API_SPARING=1 이면 Gemini 폴백 차단)",
    "발행(Playwright)은 원고·이미지 완료 후 마지막",
    "프로그램 개발: run_dev_pipeline.bat · drawer/cli.py dev-plan (FABLE→Hermes→Codex→Gemma4→Llama)"
  ],
  "dev_pipeline": {
    "description": "프로그램·기능 개발 시 설치된 에이전트 단계 순서 (블로그 agent_pipeline 과 분리)",
    "principles": [
      "Phase 0 programs_check 통과 후 시작",
      "한 번에 하나의 LLM만 (VRAM/RAM 절약)",
      "Hermes/OpenClaw로 요구사항 분해 → Fable로 LOOP·설계 감독 → Codex로 구현",
      "Gemma4는 UI문구·README·주석, Llama/DeepSeek은 로컬 보조·스크립트",
      "OpenClaw는 구현 후 Cron·채널 보고(백그라운드), Fable은 마지막 검수(선택)"
    ],
    "phases": [
      {
        "phase": 0,
        "id": "precheck",
        "label": "환경 점검",
        "llm": false,
        "role": "Python·venv·Ollama·OpenClaw·Fable 연동 확인",
        "agents": ["programs_check"],
        "command": "run_programs_check.bat --minimal"
      },
      {
        "phase": 1,
        "id": "hermes",
        "label": "요구사항·업무 분해",
        "llm": true,
        "role": "사용자 요청을 작업 단위로 쪼개고 담당 에이전트 지정",
        "agents": ["openclaw", "hermes"],
        "after": ["precheck"]
      },
      {
        "phase": 2,
        "id": "fable",
        "label": "LOOP 설계·감독",
        "llm": true,
        "heavy": true,
        "role": "수용 기준·비목표·LOOP.md 감독. 아키텍처·리스크 검토",
        "agents": ["fable"],
        "command": "run_fable5.bat apply",
        "after": ["hermes"]
      },
      {
        "phase": 3,
        "id": "codex",
        "label": "코드 구현",
        "llm": true,
        "external": true,
        "role": "파일 수정·테스트·디버그 (Cursor Agent / Codex)",
        "agents": ["codex"],
        "after": ["fable"]
      },
      {
        "phase": 4,
        "id": "gemma4",
        "label": "UI문구·README·주석",
        "llm": true,
        "role": "한글 마이크로카피·문서 초안·사용자 안내 문구",
        "agents": ["gemma4", "hermes"],
        "after": ["codex"]
      },
      {
        "phase": 5,
        "id": "llama",
        "label": "로컬 스크립트·보조",
        "llm": true,
        "optional": true,
        "role": "짧은 유틸·배치·프로토타입 (Codex 부담 줄이기)",
        "agents": ["llama", "deepseek"],
        "after": ["gemma4"]
      },
      {
        "phase": 6,
        "id": "openclaw_ops",
        "label": "백그라운드·Cron·보고",
        "llm": false,
        "role": "OpenClaw 게이트웨이·AI 직원 템플릿·Slack/Telegram 보고",
        "agents": ["openclaw"],
        "command": "run_openclaw.bat checklist",
        "after": ["codex"]
      },
      {
        "phase": 7,
        "id": "verify",
        "label": "검증·점검",
        "llm": false,
        "role": "programs_check · verify_fable_openclaw · 수동 테스트",
        "agents": ["programs_check"],
        "command": "python verify_fable_openclaw.py",
        "after": ["gemma4", "openclaw_ops"]
      }
    ]
  },
  "boot_sequence": [
    {
      "order": 0,
      "id": "check",
      "label": "프로그램 점검",
      "command": "run_programs_check.bat",
      "required": true
    },
    {
      "order": 1,
      "id": "ollama",
      "label": "Ollama 서버",
      "command": "ollama serve (별도 터미널)",
      "required": true,
      "note": "ollama pull qwen3:4b"
    },
    {
      "order": 2,
      "id": "drawer",
      "label": "서랍 모듈 확인",
      "command": "run_drawer.bat list",
      "required": true
    },
    {
      "order": 3,
      "id": "gui",
      "label": "Autoblog GUI",
      "command": "run_gui.bat",
      "required": false,
      "note": "발행·JARVIS 연동 시 필요"
    },
    {
      "order": 4,
      "id": "javis",
      "label": "JARVIS 연동 점검",
      "command": "run_javis_connect.bat",
      "required": false
    }
  ],
  "agent_pipeline": [
    {
      "order": 1,
      "id": "router",
      "label": "라우터 (문지기)",
      "tool": "drawer/router.py · run_drawer.bat route",
      "llm": false,
      "role": "키워드·module 필드만 보고 blog/store/wiki/neighbor 분기. LLM 호출 금지."
    },
    {
      "order": 2,
      "id": "wiki",
      "label": "Wiki 에이전트",
      "tool": "drawer/wiki.py · run_drawer.bat invoke wiki",
      "llm": false,
      "role": "글 유형별 지침 슬라이스만 로드. 전체 마스터 지침을 컨텍스트에 넣지 않음."
    },
    {
      "order": 3,
      "id": "ollama",
      "label": "텍스트 에이전트 (Ollama)",
      "tool": "blog_content_gen · BLOG_TEXT_PROVIDER=ollama",
      "llm": true,
      "model_env": "BLOG_OLLAMA_MODEL",
      "default_model": "qwen3:4b",
      "role": "1) 개요(제목·소제목·IMAGE_DESC) 2) 본문. 한 번에 하나의 Ollama 요청만."
    },
    {
      "order": 4,
      "id": "gemini_text",
      "label": "텍스트 폴백 (Gemini)",
      "tool": "blog_content_gen",
      "llm": true,
      "fallback_only": true,
      "skip_if": "BLOG_API_SPARING=1",
      "role": "Ollama 타임아웃·실패 시에만 outline/body 재시도."
    },
    {
      "order": 5,
      "id": "gemini_image",
      "label": "이미지 에이전트 (Gemini Image)",
      "tool": "blog_content_gen.generate_images",
      "llm": true,
      "after": ["ollama", "gemini_text"],
      "env_flag": "BLOG_IMAGE_PROVIDER=genai",
      "role": "본문·IMAGE_DESC 확정 후 키워드 맞춤 이미지 1장. 텍스트 LLM과 동시 실행 금지."
    },
    {
      "order": 6,
      "id": "publisher",
      "label": "발행 에이전트 (Playwright)",
      "tool": "blog_automation_flow · naver_module",
      "llm": false,
      "after": ["gemini_image"],
      "role": "네이버/티스토리/구글 에디터 진입·포스팅. GUI 자동화 시작 또는 JARVIS module=blog."
    },
    {
      "order": 7,
      "id": "claude",
      "label": "검수 에이전트 (Claude Code)",
      "tool": "claude CLI · Codex",
      "llm": true,
      "heavy_tasks_only": true,
      "optional": true,
      "role": "장문 재작성·지침 위반 검수·리팩터만. 일상 포스팅 파이프라인에는 끼우지 않음."
    },
    {
      "order": 8,
      "id": "codex",
      "label": "오케스트레이터 (Codex/Cursor)",
      "tool": "CODEX_DRAWER.md · drawer/cli.py",
      "llm": true,
      "role": "위 순서 감독. store는 subprocess(run_drawer invoke store). 코드 수정·디버그 담당."
    }
  ],
  "text_chain": [
    {
      "id": "ollama",
      "label": "로컬 Ollama",
      "env_model": "BLOG_OLLAMA_MODEL",
      "default_model": "qwen3:4b",
      "priority": 1,
      "cost": "free",
      "ram_mb_hint": 4096,
      "use_for": ["outline", "body", "outline+body"]
    },
    {
      "id": "gemini",
      "label": "Gemini API",
      "env_model": "BLOG_GEMINI_TEXT_MODEL",
      "default_model": "gemini-2.5-flash",
      "priority": 2,
      "cost": "paid",
      "fallback_only": true,
      "use_for": ["outline", "body", "verify"]
    },
    {
      "id": "claude",
      "label": "Claude Code CLI",
      "env_model": "BLOG_CLAUDE_MODEL",
      "default_model": "",
      "priority": 3,
      "cost": "subscription",
      "heavy_tasks_only": true,
      "use_for": ["body", "review"]
    }
  ],
  "jarvis_model_routing": {
    "description": "JARVIS 멀티 에이전트 — 작업 유형별 모델 우선순위 (Fable·OpenClaw·Hermes·Gemma4·Llama)",
    "orchestrator": "hermes",
    "dev_orchestrator_chain": ["openclaw", "hermes", "fable", "codex", "gemma4", "llama"],
    "task_categories": {
      "orchestration": {
        "label": "종합 컨트롤러",
        "priority": ["openclaw", "hermes", "fable"],
        "role": "사용자 발화 분석 → 에이전트 업무 배분 (OpenClaw 게이트웨이 우선)"
      },
      "architecture": {
        "label": "설계·LOOP 감독",
        "priority": ["fable", "hermes", "codex"],
        "role": "수용 기준·비목표·아키텍처 검토 (Claude Fable 5)"
      },
      "coding": {
        "label": "개발·자동화",
        "priority": ["codex", "deepseek", "llama", "hermes"],
        "role": "프로젝트 코드 수정·파일 자율 제어·스크립트"
      },
      "algorithm": {
        "label": "알고리즘·수학",
        "priority": ["deepseek", "codex", "hermes"],
        "role": "복잡한 로직·에러 디버깅"
      },
      "content": {
        "label": "블로그·글쓰기",
        "priority": ["gemma4", "gemma2", "hermes", "deepseek"],
        "role": "자연스러운 한글·마케팅 원고·요약"
      },
      "docs_ui": {
        "label": "문서·UI 문구",
        "priority": ["gemma4", "hermes", "gemma2"],
        "role": "README·에러 메시지·버튼 라벨·한글 마이크로카피"
      },
      "image_generate": {
        "label": "이미지 생성",
        "priority": ["deepseek_janus", "genai", "pollinations"],
        "role": "텍스트→이미지 (Janus 없으면 Gemini Image)"
      },
      "image_prompt": {
        "label": "이미지 프롬프트",
        "priority": ["hermes", "gemma2", "deepseek"],
        "role": "Flux/MJ용 정교한 IMAGE_DESC"
      }
    },
    "model_profiles": {
      "fable": {
        "label": "Claude Fable 5",
        "backend": "anthropic",
        "model_id": "claude-fable-5",
        "env": "BLOG_CLAUDE_MODEL",
        "command": "run_fable5.bat apply",
        "external": false,
        "heavy_tasks_only": true
      },
      "openclaw": {
        "label": "OpenClaw",
        "backend": "openclaw",
        "dashboard": "http://127.0.0.1:18789/",
        "command": "run_openclaw.bat",
        "external": true
      },
      "hermes": {
        "label": "Hermes 3",
        "backend": "ollama",
        "ollama_models": ["hermes3:latest", "hermes3:8b", "nous-hermes2:latest"]
      },
      "codex": {
        "label": "Codex/Cursor",
        "backend": "cursor",
        "external": true
      },
      "gemma4": {
        "label": "Gemma 4",
        "backend": "ollama",
        "ollama_models": ["gemma4:latest", "gemma4:e2b", "gemma4:31b"],
        "env": "BLOG_GEMMA4_MODEL"
      },
      "llama": {
        "label": "Llama 3",
        "backend": "ollama",
        "ollama_models": ["llama3:latest", "llama3.1:latest", "llama3.2:latest"],
        "env": "BLOG_LLAMA_MODEL"
      },
      "deepseek": {
        "label": "DeepSeek",
        "backend": "ollama",
        "ollama_models": ["deepseek-r1:8b", "deepseek-r1:1.5b"]
      },
      "gemma2": {
        "label": "Gemma 2",
        "backend": "ollama",
        "ollama_models": ["gemma2:9b", "gemma2:9b-it", "gemma2:2b"]
      },
      "deepseek_janus": {
        "label": "DeepSeek Janus",
        "backend": "ollama",
        "ollama_models": ["janus-pro", "janus"]
      },
      "genai": { "label": "Gemini Image", "backend": "gemini" },
      "pollinations": { "label": "Pollinations", "backend": "free" }
    }
  },
  "image_chain": [
    {
      "id": "genai",
      "label": "Gemini Flash Image",
      "priority": 1,
      "env_flag": "BLOG_IMAGE_PROVIDER=genai"
    },
    {
      "id": "vertex",
      "label": "Vertex Imagen",
      "priority": 2,
      "fallback_only": true
    },
    {
      "id": "pollinations",
      "label": "Pollinations 무료",
      "priority": 3,
      "env_flag": "BLOG_IMAGE_PROVIDER=free"
    }
  ],
  "workers": {
    "blog": {
      "label": "블로그 자동 포스팅",
      "imports": ["blog_automation_flow", "blog_content_gen", "playwright"],
      "subprocess_ok": false,
      "agent_order": [1, 2, 3, 4, 5, 6]
    },
    "draft": {
      "label": "원고+이미지만 (발행 없음)",
      "command": "run_draft.bat",
      "subprocess_ok": true,
      "agent_order": [1, 2, 3, 4, 5]
    },
    "store": {
      "label": "스마트스토어 마케팅",
      "imports": ["store_pipeline", "store_marketing_agent"],
      "subprocess_ok": true,
      "agent_order": [1, 8]
    },
    "neighbor": {
      "label": "서이추",
      "imports": ["naver_module"],
      "subprocess_ok": false,
      "agent_order": [6]
    },
    "verify": {
      "label": "API 검증",
      "imports": ["blog_content_gen"],
      "subprocess_ok": false,
      "agent_order": [4]
    },
    "wiki": {
      "label": "지침 Wiki 조회",
      "imports": ["drawer.wiki"],
      "subprocess_ok": true,
      "agent_order": [2]
    },
    "dev": {
      "label": "프로그램·기능 개발",
      "command": "run_dev_pipeline.bat",
      "subprocess_ok": true,
      "agent_order": [0, 1, 2, 3, 4, 5, 6, 7],
      "note": "dev_pipeline phases — FABLE→Hermes→Codex→Gemma4→Llama"
    }
  }
}
