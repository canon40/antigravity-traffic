{
  "version": 2,
  "installCommand": "pip install -r requirements-vercel.txt",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "functions": {
    "app.py": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/track",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/traffic",
      "schedule": "*/20 * * * *"
    }
  ]
}
