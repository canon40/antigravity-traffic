{
  "version": 2,
  "installCommand": "pip install -r requirements-vercel-proxy.txt",
  "rewrites": [
    {
      "source": "/api/content/:path*",
      "destination": "/api/hub_content"
    },
    {
      "source": "/api/:path*",
      "destination": "https://port-0-antigravity-traffic-mqg8473t248a0738.sel3.cloudtype.app/api/:path*"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/manifest.json",
      "dest": "/static/manifest.json"
    },
    {
      "src": "/sw.js",
      "dest": "/static/sw.js"
    },
    {
      "src": "/openapi.json",
      "dest": "/openapi.json"
    },
    {
      "src": "/(.*)",
      "dest": "/templates/index.html"
    }
  ],
  "functions": {
    "api/hub_content.py": {
      "maxDuration": 30
    }
  }
}
