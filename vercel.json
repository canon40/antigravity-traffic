{
  "version": 2,
  "installCommand": "pip install -r requirements-vercel-proxy.txt",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/proxy.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/manifest.json",
      "dest": "/static/manifest.json"
    },
    {
      "src": "/sw.js",
      "dest": "/static/sw.js"
    },
    {
      "src": "/openapi.json",
      "dest": "/openapi.json"
    },
    {
      "src": "/(.*)",
      "dest": "/templates/index.html"
    }
  ],
  "functions": {
    "api/proxy.py": {
      "maxDuration": 60
    }
  }
}
