# Gemini (음성 JARVIS Live API)
GEMINI_API_KEY=

# Anthropic (Claude Opus + 서버 웹검색 web_search_20260209)
ANTHROPIC_API_KEY=
ANTHROPIC_SEARCH_MODEL=claude-opus-4-7
ANTHROPIC_WEB_SEARCH_TYPE=web_search_20260209

# Grok / xAI (영상 프로그램 스토리보드·Grok Build)
XAI_API_KEY=
XAI_MODEL=grok-4-1-fast

# DeepSeek (Hermes 브릿지가 동기화 가능)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Llama — 로컬 Ollama (code_helper / spark 텍스트용)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.6
OLLAMA_CODER_MODEL=deepseek-r1:8b
OLLAMA_REVIEWER_MODEL=qwen3.6
OLLAMA_DEEPSEEK_MODEL=deepseek-r1:8b
OLLAMA_QWEN_MODEL=qwen3.6
OLLAMA_GEMMA_MODEL=gemma2
OLLAMA_GEMMA4_MODEL=gemma3
OLLAMA_VISION_MODEL=minicpm-v
LOCAL_LLM_PROFILE=balanced
LOCAL_LLM_SKIP_LARGE=0
# JARVIS_LLM_BACKEND=gemini | deepseek | ollama

# 총괄 디렉터 (Gemini + Hermes/Llama 멀티 에이전트)
JARVIS_DIRECTOR_MODEL=gemini-3.1-pro-preview
JARVIS_DIRECTOR_FLASH_MODEL=gemini-3.1-flash-lite

# Open Lovable (Firecrawl 웹 스크래핑 — https://firecrawl.dev)
FIRECRAWL_API_KEY=
JARVIS_USE_OPEN_LOVABLE=1
OPEN_LOVABLE_URL=http://localhost:3000

# GenSpark2API — https://github.com/deanxv/genspark2api
GS_COOKIE=
GENSPARK2API_URL=http://127.0.0.1:7055
GENSPARK2API_SECRET=123456
GENSPARK_SEARCH_MODEL=gemini-2.5-flash-search
GENSPARK_CHAT_MODEL=gemini-2.5-pro
RECAPTCHA_PROXY_URL=

# Skywork Skills API — https://skywork.ai/skill-landing
SKYWORK_API_KEY=
MUREKA_API_KEY=

# 플랫폼 upstream만 사용 (0=Gemini 폴백 허용)
JARVIS_PLATFORM_STRICT=0

# Meta AI 무료 생성 — https://youtu.be/GOf-vBW8e_w
META_AI_URL=https://www.meta.ai/
META_AI_VIDEO_URL=https://www.meta.ai/ai-video-generator
META_AI_IMAGE_URL=https://www.meta.ai/ai-image-generator
META_AI_AUTO_BROWSER=1
META_AI_HEADLESS=0
META_AI_WAIT_LOGIN_SEC=300
META_AI_WAIT_RESULT=1
META_AI_GENERATION_TIMEOUT_SEC=180
META_AI_USE_GENSPARK_FALLBACK=1
META_AI_VIDEO_MODEL=gemini/veo3/fast

# 연산·성능 (기능 많을 때 필수)
JARVIS_FAST_AGENTS=1
JARVIS_COUNCIL_LITE=1
JARVIS_COUNCIL_MAX_ROUNDS=3
JARVIS_MAX_CONCURRENT_TASKS=2
JARVIS_SKIP_OLLAMA=0
OLLAMA_TIMEOUT_SEC=90
# Claude Code — backend: ollama | free_cc | anthropic
# free_cc = https://github.com/Alishahryar1/free-claude-code (영상 nZY_Cxw0svo)
JARVIS_CLAUDE_BACKEND=ollama
JARVIS_FCC_PORT=8082
JARVIS_FCC_AUTH_TOKEN=freecc
OPENCODE_API_KEY=
OPENROUTER_API_KEY=

# Julian SEO Agent OS — Obsidian · Netlify · Omega Indexer
OBSIDIAN_VAULT_PATH=
NETLIFY_DEPLOY_HOOK_URL=
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
OMEGA_INDEXER_API_KEY=
OMEGA_INDEXER_WEBHOOK_URL=
OMEGA_INDEXER_API_URL=
NVIDIA_NIM_API_KEY=

# Claude Code — 로컬 Ollama (JARVIS_CLAUDE_BACKEND=ollama 일 때)
JARVIS_USE_CLAUDE_CODE=1
JARVIS_CLAUDE_LOCAL=1
JARVIS_CLAUDE_OLLAMA_PROXY=1
JARVIS_CLAUDE_TIMEOUT_SEC=600
# OLLAMA_ANTHROPIC_BASE_URL=http://localhost:11434/v1
# 검수도 로컬 Llama 쓰려면: JARVIS_FAST_AGENTS=0
# 클라우드 Claude 쓰려면(선택): JARVIS_CLAUDE_USE_ANTHROPIC=1 + ANTHROPIC_API_KEY=
JARVIS_AUTO_AGENTS=1

# 쇼츠 1단계 기획 — gemini(기본) | ollama(로컬)
JARVIS_SHORTS_PLANNER=gemini
# JARVIS_SHORTS_PLANNER=ollama
JARVIS_WHISPER_SYNC=0
JARVIS_PREMIUM_TTS_RATE=+12%
PEXELS_API_KEY=

# n8n → Jarvis 웹훅 (integrations/n8n_webhook_bridge.py)
JARVIS_N8N_PORT=8765

# Edge TTS — 한국어 로컬 음성 (ko-KR-SunHiNeural)
JARVIS_EDGE_TTS=1
JARVIS_EDGE_VOICE=ko-KR-SunHiNeural
JARVIS_EDGE_RATE=+0%
JARVIS_EDGE_PITCH=-5Hz

# Hermes agent ai (영상·SEO·Spark 워크플로)
HERMES_BRIDGE=1
HERMES_ROOT=d:\@code\agent ai
# Hermes Desktop / Agent (fathah/hermes-desktop → NousResearch/hermes-agent)
HERMES_HOME=%USERPROFILE%\.hermes
HERMES_API_URL=http://127.0.0.1:8642
# Claw3D Studio (iamlukethedev/Claw3D)
CLAW3D_ROOT=d:\@code\Claw3D
CLAW3D_STUDIO_URL=http://127.0.0.1:3000
CLAW3D_GATEWAY_URL=ws://127.0.0.1:18789
# CloakBrowser (선택) — pip install cloakbrowser
JARVIS_USE_CLOAKBROWSER=0

# 보조 에이전트
GEMINI_SPARK_ENABLED=1
JARVIS_SPARK_AGENT=1
VIDEO_MAKE_ENABLED=1
VIDEO_MAKE_MODE=seedance
VIDEO_MAKE_SCENES=4
JARVIS_VIDEO_ALLOW_FALLBACK=0
# AI 애니메이션 영화 (YouTube 2f9KTBAXtmE)
ANIMATION_FILM_ENABLED=1
# G2G 20 OSS 생태계 (YouTube 6lypZ_4clDY)
G2G_ECOSYSTEM_ENABLED=1
# AI 토킹헤드 SoulX-FlashHead (YouTube npto_x2euzs)
TALKING_HEAD_ENABLED=1
# config/avatar.json — JARVIS 음성 종료 후 자동 아바타 (enabled: true)
VIDEO_MAKE_REFERENCE=https://youtu.be/iFlQsL-NvcU
SEEDANCE_START_URL=https://seedance2.kr/

# Supabase — JARVIS 모바일 프로그램 프리셋·원격 명령 큐 (sql/jarvis_mobile_schema.sql 실행)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Cloudtype + Vercel (프론트는 Vercel, API는 Cloudtype 프록시)
# Vercel 프로젝트 환경변수에도 동일하게 설정:
# CLOUDTYPE_API_BASE=https://<cloudtype-public-domain>
CLOUDTYPE_API_BASE=
